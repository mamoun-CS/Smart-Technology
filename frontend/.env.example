# Smart Technology Frontend Environment Variables

# API Configuration
NEXT_PUBLIC_API_URL=http://publicity-therapy-coleman-pulse.trycloudflare.com/api

# Application Settings
NEXT_PUBLIC_APP_NAME=Smart Technology
NEXT_PUBLIC_APP_URL=http://localhost:3000/
NEXT_PUBLIC_APP_EMAIL=info@smarttech.com
NEXT_PUBLIC_APP_DESCRIPTION=Premium Shopping Experience

# Image Configuration (for Next.js Image component)
NEXT_PUBLIC_IMAGE_DOMAINS=localhost,res.cloudinary.com,images.unsplash.com,3121-195-123-167-82.ngrok-free.app,publicity-therapy-coleman-pulse.trycloudflare.com

# Authentication
NEXT_PUBLIC_TOKEN_KEY=accessToken
NEXT_PUBLIC_USER_KEY=user

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true

# Development Settings
NEXT_PUBLIC_DEBUG_MODE=true
