# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smart_technology
DB_USER=postgres
DB_PASSWORD=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Google OAuth (for social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ---------------------------------------------------------------
# Zoho Mail API (email sending)
# ---------------------------------------------------------------
# To obtain credentials, follow these steps:
#   1. Go to https://admin-console.zoho.com/ and sign in
#   2. Navigate to Mail → Settings → SMTP & IMAP
#   3. Enable SMTP access and generate an OAuth refresh token
#   4. Get your account ID from Mail → Domains
# ---------------------------------------------------------------
ZOHO_EMAIL=
ZOHO_ACCOUNT_ID=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_API_BASE_URL=https://mail.zoho.com
ZOHO_OAUTH_BASE_URL=https://accounts.zoho.com

# Admin email (recipient for contact form & admin notifications)
ADMIN_EMAIL=admin@smarttech.com
